<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PrjVinculo.MainPage">

    <ScrollView>
       <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Label
                Text="Página Inicial"
                FontSize="Header"
                VerticalTextAlignment="Center"
                HorizontalTextAlignment="Center"
                TextColor="Tomato"
               />
            <Button
                Text="Produto"
                x:Name="btnProduto"
                Clicked="btnProduto_Clicked"
                FontSize="Large"
                />
               
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
